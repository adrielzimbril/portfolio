# ============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION
# ============================================================================
# This file contains all the environment variables needed to run the application.
# Copy this file to .env.local and fill in the actual values.
# Never commit .env.local to version control.
#
# Variable Naming Convention:
# - NEXT_PUBLIC_*: Exposed to the browser (client-side accessible)
# - NEXT_PRIVATE_*: Server-side only (never exposed to browser)
# - No prefix: Server-side only (legacy, prefer NEXT_PRIVATE_ for clarity)
#
# Access variables in code via: import { ConfigValue } from "@/config"
# ============================================================================

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
# The environment in which the application is running
# Options: "development", "production", "test"
NODE_ENV="production"

# Server port (default: 3000)
PORT=3000

# ============================================================================
# SITE CONFIGURATION
# ============================================================================
# The base URL of your site (used for canonical URLs, sitemaps, etc.)
# In development: http://localhost:3000
# In production: https://yourdomain.com
# 
# PERFORMANCE MONITORING
# Site URL for PageSpeed Insights
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Custom domain for your site (optional, for CDN/proxy setups)
NEXT_PUBLIC_DOMAIN_SITE_URL=

# Custom domain for S3-hosted assets (optional)
NEXT_PUBLIC_S3_DOMAIN_SITE_URL=

# Vercel deployment URL (auto-set by Vercel, usually don't need to set manually)
NEXT_PUBLIC_VERCEL_URL=

# ============================================================================
# SITE REVAMP DATE
# ============================================================================
# The date when your site was last significantly redesigned or revamped
# Used in stats page to show "Days since revamp"
# Format: YYYY-MM-DD (e.g., "2025-08-17")
NEXT_PUBLIC_REVAMP_DATE="2025-08-17"

# ============================================================================
# API SECURITY KEYS
# ============================================================================
# Secret key for API validation and authentication
# Generate a random string: openssl rand -base64 32
API_SECRET_KEY=InB1

# Secret key for health check endpoints
# Used to secure health check routes from unauthorized access
HEALTH_CHECK_SECRET_KEY=InB1

# Secret key for Next.js revalidation
# Used for on-demand ISR (Incremental Static Regeneration) webhooks
# Generate a random string: openssl rand -base64 32
NEXT_REVALIDATION_SECRET=

# ============================================================================
# GITHUB INTEGRATION
# ============================================================================
# GitHub Personal Access Token for fetching repository statistics
# Required scopes: repo (public_repo is sufficient for public repos)
# Generate at: https://github.com/settings/tokens
NEXT_PRIVATE_GITHUB_TOKEN=

# Your GitHub username (public)
NEXT_PUBLIC_GITHUB_USERNAME=

# Your GitHub repository name (public)
NEXT_PUBLIC_GITHUB_REPO=

# Default branch to track (public, default: main)
NEXT_PUBLIC_GITHUB_BRANCH=main

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Authentication Provider: "supabase" (default) or "betterauth"
AUTH_PROVIDER="supabase"

# Callback URLs for different destinations
AUTH_CALLBACK_URL_COMMUNITY="/community"
AUTH_CALLBACK_URL_DEFAULT="/"
AUTH_DEFAULT_REDIRECT="/"

# Base URL for Better Auth (default: http://localhost:3000)
BETTER_AUTH_URL="http://localhost:3000"

# Secret key for Better Auth (authentication library)
# Generate a secure random string: openssl rand -base64 32
# This is critical for security - keep it secret and rotate periodically
BETTER_AUTH_SECRET="A_RANDOM_SECRET_STRING"

# Admin emails (comma-separated list of emails allowed to access admin panel)
# Only these emails will be able to access the /admin page
NEXT_PRIVATE_ADMIN_EMAILS="admin@example.com,another-admin@example.com"

# Session timeout in hours (default: 1 hour)
# Users will be automatically logged out after this period of inactivity
NEXT_PRIVATE_SESSION_TIMEOUT_HOURS="1"

# ============================================================================
# DATABASE
# ============================================================================
# Database connection string (server-side only)
# Required for database backups
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Or mysql://user:password@host:port/database
DATABASE_URL=

# ============================================================================
# DATABASE (SUPABASE)
# ============================================================================
# Supabase project URL (public)
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public key (public)
# This key is safe to expose to the browser as it has limited permissions
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-side only, secret)
# This key has full admin access and bypasses RLS policies
# Use only in server-side code for admin operations
# Get from: https://supabase.com/dashboard/project/_/settings/api
# Format: sb_secret_*
NEXT_PRIVATE_SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# EMAIL & CONTACT FORMS
# ============================================================================
# Contact form provider: "logger" (dev), "brevo", "resend", or custom
CONTACTS_PROVIDER=

# Email service provider: "logger" (dev), "brevo", "resend", or custom
MAIL_PROVIDER=

# Default sender email address
SENDER_EMAIL="bonjour@adrielzimbril.com"

# Default sender name
SENDER_NAME="Adriel Zimbril"

# ----------------------------------------------------------------------------
# Brevo (formerly Sendinblue) Configuration
# ----------------------------------------------------------------------------
# Brevo API key for sending emails
# Get from: https://app.brevo.com/apikeys
BREVO_API_KEY=

# Brevo audience/list IDs for different content types
# Get from: https://app.brevo.com/contacts/lists
BREVO_GENERAL_LIST_ID="18"
BREVO_COURSE_LIST_ID="20"
BREVO_VIDEO_LIST_ID="19"
BREVO_EBOOKS_LIST_ID="21"
BREVO_MASTERCLASS_LIST_ID="22"
BREVO_FIGMA_TEMPLATE_LIST_ID="23"
BREVO_CODE_LIST_ID="24"
BREVO_QUESTS_REGISTER_ID="25"
BREVO_QUESTS_SUBMISSIONS_ID="26"

# ----------------------------------------------------------------------------
# Resend Configuration
# ----------------------------------------------------------------------------
# Resend API key for sending emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=""

# Resend audience IDs for different content types
RESEND_GENERAL_LIST_ID=""
RESEND_COURSE_LIST_ID=""
RESEND_VIDEO_LIST_ID=""
RESEND_EBOOKS_LIST_ID=""

# ============================================================================
# PAYMENT PROCESSING
# ============================================================================
# ----------------------------------------------------------------------------
# LemonSqueezy Configuration
# ----------------------------------------------------------------------------
# LemonSqueezy API key
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=""

# LemonSqueezy webhook secret for signature verification
# Get from: https://app.lemonsqueezy.com/settings/webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=""

# LemonSqueezy store ID
# Get from: https://app.lemonsqueezy.com/settings/general
LEMONSQUEEZY_STORE_ID=""

# ----------------------------------------------------------------------------
# Stripe Configuration
# ----------------------------------------------------------------------------
# Stripe secret key (starts with sk_live_ or sk_test_)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""

# Stripe webhook secret for signature verification
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=""

# ============================================================================
# TASK SCHEDULING
# ============================================================================
# Trigger.dev access token for scheduled tasks
# Get from: https://trigger.dev/dashboard
TRIGGER_ACCESS_TOKEN=""

# Trigger.dev public app URL (for scheduled tasks)
NEXT_TRIGGER_PUBLIC_APP_URL=

# ============================================================================
# VERCEL CRON
# ============================================================================
# Secret key for Vercel cron job authentication
# Used to secure cron endpoints from unauthorized access
# Generate a random string: openssl rand -base64 32
VERCEL_CRON_SECRET=

# Bundle analyzer (set to "true" to analyze bundle size)
# Run with: pnpm analyze
ANALYZE_BUNDLE=""

# ============================================================================
# ANALYTICS
# ============================================================================
# ----------------------------------------------------------------------------
# PostHog Configuration
# ----------------------------------------------------------------------------
# PostHog project ID (server-side)
NEXT_PRIVATE_POSTHOG_CODE=""

# PostHog API key (server-side)
NEXT_PRIVATE_POSTHOG_KEY=

# PostHog API key (public, exposed to browser)
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog personal API key (for admin operations)
NEXT_PRIVATE_POSTHOG_PERSONAL_KEY=

# PostHog host URL
# Default: https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ----------------------------------------------------------------------------
# Plausible Configuration
# ----------------------------------------------------------------------------
# Plausible analytics domain URL
# Example: https://analytics.yourdomain.com or https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_URL=""

# ----------------------------------------------------------------------------
# Google Analytics Configuration
# ----------------------------------------------------------------------------
# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
# Get from: https://analytics.google.com/admin
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""

# ============================================================================
# CLOUD STORAGE (S3 COMPATIBLE)
# ============================================================================
# S3 access key ID
# Get from your S3 provider (AWS, DigitalOcean Spaces, MinIO, etc.)
S3_ACCESS_KEY_ID=""

# S3 secret access key
S3_SECRET_ACCESS_KEY=""

# S3 endpoint URL
# Examples:
# - AWS: https://s3.amazonaws.com
# - DigitalOcean: https://nyc3.digitaloceanspaces.com
# - MinIO: http://localhost:9000
S3_ENDPOINT=""

# S3 region
# Examples: us-east-1, nyc3, etc.
S3_REGION=""

# S3 bucket name for avatars (public, exposed to browser, default: avatars)
NEXT_PUBLIC_AVATARS_BUCKET_NAME=avatars

# S3 bucket name for database backups (server-side only, default: database-backups)
S3_BACKUP_BUCKET=database-backups

# ============================================================================
# AI & MACHINE LEARNING
# ============================================================================
# ----------------------------------------------------------------------------
# OpenAI Configuration (Optional)
# ----------------------------------------------------------------------------
# OpenAI API key for GPT models
# Used for: Markdown file translations and i18n nextintl translations
# Get from: https://platform.openai.com/api-keys
# Note: This is optional - the app works without it
OPENAI_API_KEY=

# ============================================================================
# BOT PROTECTION & CAPTCHA
# ============================================================================
# ----------------------------------------------------------------------------
# Google reCAPTCHA v2 Configuration
# ----------------------------------------------------------------------------
# reCAPTCHA site key (public)
# Get from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# reCAPTCHA secret key (server-side)
NEXT_PRIVATE_RECAPTCHA_SECRET_KEY=

# ----------------------------------------------------------------------------
# Cloudflare Turnstile Configuration
# ----------------------------------------------------------------------------
# Turnstile site key (public)
# Get from: https://dash.cloudflare.com/?to=turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Turnstile secret key (server-side, recommended)
NEXT_PRIVATE_TURNSTILE_SECRET_KEY=

# Google PageSpeed Insights API key
# Used to fetch Lighthouse scores for performance monitoring
# Get from: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Lighthouse cache duration in days (default: 10)
LIGHTHOUSE_CACHE_DAYS=10

# ============================================================================
# LEGACY / OTHER VARIABLES
# ============================================================================
# REST API endpoint (legacy, may not be used)
NEXT_PUBLIC_REST_API_ENDPOINT=

# ============================================================================
# DEVELOPMENT NOTES
# ============================================================================
# 1. Always use .env.local for local development (never commit it)
# 2. Use .env.example as a template for required variables
# 3. Variables starting with NEXT_PUBLIC_ are exposed to the browser
# 4. Never store sensitive data in NEXT_PUBLIC_ variables
# 5. Rotate secrets regularly, especially in production
# 6. Use different secrets for development and production environments
# 7. Test all integrations after setting up environment variables
# 8. Access env vars in code via: import { ConfigValue } from "@/config"
# 9. The validation utility will check for required variables on startup
# ============================================================================