{
  "name": "@squircle/core",
  "version": "1.0.6",
  "homepage": "https://squircle.skyleen.dev",
  "author": "Skyleen",
  "description": "A library for creating beautiful squircles in CSS, offering full customization and seamless integration as well as Tailwind CSS integration.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "squircle"
  ],
  "license": "MIT",
  "devDependencies": {
    "@squircle/paint-polyfill": "workspace:*",
    "@types/node": "^22.15.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@squircle/paint-polyfill": "^1.0.3"
  }
}
